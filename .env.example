# TickTick OAuth (create app at TickTick developer portal)
TICKTICK_CLIENT_ID=
TICKTICK_CLIENT_SECRET=
TICKTICK_REDIRECT_URI=

# Webhook verification (HMAC-SHA256 secret from TickTick webhook registration)
TICKTICK_WEBHOOK_SECRET=

# Database (Vercel Postgres: use POSTGRES_URL from Vercel dashboard, or DATABASE_URL)
POSTGRES_URL=
DATABASE_URL=

# Optional: session/auth signing (e.g. for future auth)
NEXTAUTH_SECRET=
